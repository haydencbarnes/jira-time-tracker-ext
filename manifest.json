{
  "manifest_version": 3,
  "name": "Jira Log Time",
  "version": "1.5.0",
  "description": "Log/Track your time in Jira in seconds!",
  "host_permissions": ["<all_urls>"],
  "permissions": ["storage", "sidePanel"],
  "background": {
    "service_worker": "dist/timerFeatureModule/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/jira-issue-detection.js", "dist/floating-timer-widget.js"],
      "css": ["src/content-script.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": "src/icons/jira_logo.png",
    "default_popup": "dist/popup.html"
  },
  "side_panel": {
    "default_path": "dist/popup.html"
  },
  "options_page": "dist/options.html",
  "icons": {
    "16": "src/icons/jira_logo16.png",
    "48": "src/icons/jira_logo48.png",
    "128": "src/icons/jira_logo128.png"
  }
}
